-- ╔══════════════════════════════════════════════════════════════════╗
-- ║  Row-Level Security (RLS) — Power BI Dynamic Security          ║
-- ║                                                                  ║
-- ║  Mô hình: Dynamic RLS dựa trên USERPRINCIPALNAME()             ║
-- ║  Manager chỉ thấy dữ liệu vùng mình quản lý.                  ║
-- ║                                                                  ║
-- ║  Cách triển khai:                                                ║
-- ║  1. Tạo bảng SecurityMapping (trong Power BI hoặc Databricks)   ║
-- ║  2. Tạo Roles + DAX filters                                     ║
-- ║  3. Assign user/group vào Role trên Power BI Service            ║
-- ╚══════════════════════════════════════════════════════════════════╝


-- ====================================================================
-- BƯỚC 1: Tạo bảng SecurityMapping
--         Lưu trong Gold layer hoặc Import trực tiếp vào Power BI.
-- ====================================================================

-- Option A: Tạo trên Databricks (recommended — Single Source of Truth)
-- Chạy trên Databricks notebook hoặc SQL Warehouse:

-- CREATE TABLE IF NOT EXISTS sales_analytics.gold.security_mapping (
--     user_email       STRING   NOT NULL COMMENT 'UPN — email Azure AD',
--     display_name     STRING   NOT NULL COMMENT 'Tên hiển thị',
--     role             STRING   NOT NULL COMMENT 'Manager / Analyst / Director',
--     allowed_region   STRING   NOT NULL COMMENT 'Region được phép xem',
--     PRIMARY KEY (user_email, allowed_region)
-- );
--
-- INSERT INTO sales_analytics.gold.security_mapping VALUES
--     ('manager_north@contoso.com', 'Nguyễn Văn A', 'Manager', 'North'),
--     ('manager_south@contoso.com', 'Trần Thị B',   'Manager', 'South'),
--     ('manager_east@contoso.com',  'Lê Văn C',     'Manager', 'East'),
--     ('manager_west@contoso.com',  'Phạm Thị D',   'Manager', 'West'),
--     ('director@contoso.com',      'Hoàng Văn E',  'Director', 'North'),
--     ('director@contoso.com',      'Hoàng Văn E',  'Director', 'South'),
--     ('director@contoso.com',      'Hoàng Văn E',  'Director', 'East'),
--     ('director@contoso.com',      'Hoàng Văn E',  'Director', 'West'),
--     ('analyst_01@contoso.com',    'Đỗ Văn F',     'Analyst', 'North'),
--     ('analyst_01@contoso.com',    'Đỗ Văn F',     'Analyst', 'South');

