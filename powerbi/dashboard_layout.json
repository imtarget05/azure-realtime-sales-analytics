          },
          "bounds": { "x": 862, "y": 370, "width": 390, "height": 170 }
        },
        {
          "type": "clusteredBarChart",
          "title": "Doanh thu theo phương thức thanh toán",
          "axis": "customer_summary[preferred_payment]",
          "values": ["Customer Total Spent"],
          "bounds": { "x": 96, "y": 550, "width": 560, "height": 155 }
        },
        {
          "type": "columnChart",
          "title": "Tenure Days Distribution",
          "axis": "customer_summary[tenure_days]",
          "values": ["Active Customers"],
          "bounds": { "x": 672, "y": 550, "width": 580, "height": 155 },
          "notes": "Histogram — group by tenure bins"
        }
      ]
    },

    {
