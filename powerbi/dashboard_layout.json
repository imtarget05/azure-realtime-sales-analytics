            "accentColor": "#3B82F6",
            "bounds": { "x": 984, "y": 70, "width": 280, "height": 100 }
          }
        ]
      },

      "visuals": [
        {
          "type": "table",
          "title": "Top Customers (Xếp hạng)",
          "columns": [
            "Customer Revenue Rank",
