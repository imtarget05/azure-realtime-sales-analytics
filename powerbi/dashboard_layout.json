{
  "$schema": "custom",
  "metadata": {
    "name": "SalesAnalytics_Dashboard_Layout",
    "description": "Power BI report layout — 4 pages + navigation sidebar. Áp dụng qua Tabular Editor hoặc tham chiếu khi xây dựng báo cáo thủ công.",
    "version": "1.0.0",
    "theme": "powerbi/themes/SalesAnalytics_Dark.json",
    "canvasSize": {
      "desktop": { "width": 1280, "height": 720 },
      "mobile":  { "width": 360, "height": 640 }
    }
  },

  "navigation": {
    "type": "sidebar",
    "position": "left",
    "description": "Sidebar cố định bên trái (80px desktop, ẩn trên mobile). Dùng Buttons + Bookmarks để chuyển page.",
    "width": 80,
    "background": "#0B1120",
    "borderRight": "1px solid #1E293B",

    "logo": {
      "type": "image",
      "position": { "x": 10, "y": 12, "width": 60, "height": 60 },
      "description": "Logo công ty (60×60 PNG, transparent background). Insert → Image."
    },

    "items": [
      {
        "id": "nav_overview",
        "icon": "📊",
        "iconUnicode": "U+1F4CA",
        "label": "Tổng quan",
        "tooltip": "Tổng quan thời gian thực",
        "targetPage": "01_Overview",
        "position": { "x": 10, "y": 90, "width": 60, "height": 48 },
        "style": {
          "fillDefault": "#0B1120",
          "fillActive": "#1E293B",
          "fillHover": "#162032",
          "iconColor": "#94A3B8",
          "iconColorActive": "#00D4AA",
          "borderRadius": 12,
          "borderLeft_active": "3px solid #00D4AA"
        },
        "bookmark": "BM_Page_Overview"
      },
      {
        "id": "nav_products",
        "icon": "🏷️",
        "iconUnicode": "U+1F3F7",
        "label": "Sản phẩm",
        "tooltip": "Phân tích sản phẩm + ML Viral",
        "targetPage": "02_Products",
        "position": { "x": 10, "y": 148, "width": 60, "height": 48 },
        "style": {
          "fillDefault": "#0B1120",
          "fillHover": "#162032",
          "iconColor": "#94A3B8",
          "iconColorActive": "#3B82F6",
          "borderRadius": 12,
          "borderLeft_active": "3px solid #3B82F6"
        },
        "bookmark": "BM_Page_Products"
      },
      {
        "id": "nav_customers",
        "icon": "👥",
        "iconUnicode": "U+1F465",
        "label": "Khách hàng",
        "tooltip": "Customer Insights + CLV",
        "targetPage": "03_Customers",
        "position": { "x": 10, "y": 206, "width": 60, "height": 48 },
        "style": {
          "fillDefault": "#0B1120",
          "fillHover": "#162032",
          "iconColor": "#94A3B8",
          "iconColorActive": "#F59E0B",
          "borderRadius": 12,
          "borderLeft_active": "3px solid #F59E0B"
        },
        "bookmark": "BM_Page_Customers"
      },
      {
        "id": "nav_anomaly",
        "icon": "⚡",
        "iconUnicode": "U+26A1",
        "label": "Bất thường",
        "tooltip": "Cảnh báo & Tác động",
        "targetPage": "04_Anomaly",
        "position": { "x": 10, "y": 264, "width": 60, "height": 48 },
        "style": {
          "fillDefault": "#0B1120",
          "fillHover": "#162032",
          "iconColor": "#94A3B8",
          "iconColorActive": "#EF4444",
          "borderRadius": 12,
          "borderLeft_active": "3px solid #EF4444"
        },
        "bookmark": "BM_Page_Anomaly"
      },
      {
        "id": "nav_access_rights",
        "icon": "🔐",
        "iconUnicode": "U+1F510",
        "label": "Quyền truy cập",
        "tooltip": "Access Right — Quản lý quyền",
        "targetPage": "05_AccessRights",
        "position": { "x": 10, "y": 322, "width": 60, "height": 48 },
        "style": {
          "fillDefault": "#0B1120",
          "fillHover": "#162032",
          "iconColor": "#94A3B8",
          "iconColorActive": "#A855F7",
          "borderRadius": 12,
          "borderLeft_active": "3px solid #A855F7"
        },
        "bookmark": "BM_Page_AccessRights"
      }
    ],

    "footer": {
      "description": "Hiển thị Current User Name + Role (từ RLS DAX measures)",
      "position": { "x": 10, "y": 640, "width": 60, "height": 60 },
      "measures": ["Current User Name", "Current User Role"]
    },

    "howToCreate": [
      "1. Trên mỗi page, thêm Rectangle shape (x=0, y=0, w=80, h=720), fill=#0B1120",
      "2. Thêm 5 Action Buttons bên trong rectangle tại vị trí y tương ứng",
      "3. Mỗi button: Action = Bookmark, Bookmark = BM_Page_xxx",
      "4. Tạo 5 Bookmarks (View → Bookmarks): BM_Page_Overview, BM_Page_Products, BM_Page_Customers, BM_Page_Anomaly, BM_Page_AccessRights",
      "5. Mỗi bookmark: Display tab = trang tương ứng, Data = giữ nguyên filters",
      "6. Copy rectangle + buttons sang tất cả 5 pages (Ctrl+C / Ctrl+V)",
      "7. Trên mỗi page, highlight button active bằng fill=#1E293B + border-left accent color"
    ]
  },

  "pages": [

    {
      "name": "01_Overview",
      "displayName": "Tổng quan thời gian thực",
      "description": "KPI cards + revenue time-series + regional breakdown. Auto Page Refresh enabled.",
      "contentArea": {
        "x": 80, "y": 0, "width": 1200, "height": 720,
        "note": "Vùng nội dung = canvas trừ sidebar (1280 - 80 = 1200)"
      },

      "header": {
        "description": "Topbar: tiêu đề + slicers ngày & region",
        "bounds": { "x": 80, "y": 0, "width": 1200, "height": 60 },
        "background": "#0F172A",
        "elements": [
          {
            "type": "textbox",
            "text": "📊 Real-time Sales Overview",
            "fontSize": 18,
            "fontWeight": "semibold",
            "color": "#F1F5F9",
            "bounds": { "x": 96, "y": 12, "width": 350, "height": 36 }
          },
          {
            "type": "slicer",
            "field": "Calendar[Date]",
            "slicerType": "RelativeDate",
            "defaultValue": "Last 7 days",
            "bounds": { "x": 680, "y": 10, "width": 240, "height": 40 }
          },
          {
            "type": "slicer",
            "field": "hourly_summary[region]",
            "slicerType": "Dropdown",
            "bounds": { "x": 940, "y": 10, "width": 160, "height": 40 }
          },
          {
            "type": "slicer",
            "field": "hourly_summary[category]",
            "slicerType": "Dropdown",
            "bounds": { "x": 1120, "y": 10, "width": 150, "height": 40 }
          }
        ]
      },

      "kpiRow": {
        "description": "4 KPI cards ngang — bo góc, đổ bóng, conditional color",
        "bounds": { "x": 96, "y": 70, "width": 1168, "height": 110 },
        "cards": [
          {
            "measure": "Revenue Total",
            "subtitle": "Tổng doanh thu",
            "format": "#,##0",
            "icon": "💰",
            "accentColor": "#00D4AA",
            "subMeasure": "DoD Arrow",
            "bounds": { "x": 96, "y": 70, "width": 275, "height": 110 }
          },
          {
            "measure": "Order Total",
            "subtitle": "Tổng đơn hàng",
            "format": "#,##0",
            "icon": "📦",
            "accentColor": "#3B82F6",
            "bounds": { "x": 387, "y": 70, "width": 275, "height": 110 }
          },
          {
            "measure": "Average Order Value",
            "subtitle": "Giá trị TB/đơn",
            "format": "#,##0.00",
            "icon": "📈",
            "accentColor": "#F59E0B",
            "conditionalColor": "AOV Color",
            "bounds": { "x": 678, "y": 70, "width": 275, "height": 110 }
          },
          {
            "measure": "Active Customers",
            "subtitle": "Khách hoạt động",
            "format": "#,##0",
            "icon": "👥",
            "accentColor": "#8B5CF6",
            "bounds": { "x": 969, "y": 70, "width": 275, "height": 110 }
          }
        ]
      },

      "visuals": [
        {
          "type": "lineChart",
          "title": "Doanh thu theo giờ",
          "axis_x": "hourly_summary[hour_timestamp]",
          "values": ["Revenue Total"],
          "legend": "hourly_summary[region]",
          "bounds": { "x": 96, "y": 195, "width": 750, "height": 250 },
          "notes": "Trend line chính — real-time. Tooltip: revenue, order_count, avg_temperature"
        },
        {
          "type": "clusteredBarChart",
          "title": "Doanh thu theo vùng",
          "axis": "hourly_summary[region]",
          "values": ["Revenue Total"],
          "conditionalFormatting": {
            "dataBar": true,
            "color": "#3B82F6"
          },
          "bounds": { "x": 862, "y": 195, "width": 390, "height": 250 },
          "notes": "Bar ngang, sort DESC"
        },
        {
          "type": "donutChart",
          "title": "Revenue % theo danh mục",
          "category": "hourly_summary[category]",
          "values": ["Revenue Total"],
          "bounds": { "x": 96, "y": 460, "width": 350, "height": 245 },
          "notes": "Inner label: % of total"
        },
        {
          "type": "table",
          "title": "Top 5 Khách hàng",
          "columns": [
            "customer_summary[customer_id]",
            "customer_summary[customer_segment]",
            "Customer Total Spent",
            "customer_summary[total_orders]",
            "customer_summary[clv_tier]"
          ],
          "topNFilter": { "measure": "Customer Total Spent", "n": 5, "direction": "DESC" },
          "conditionalFormatting": {
            "clv_tier": {
              "Platinum": "#00D4AA",
              "Gold": "#F59E0B",
              "Silver": "#94A3B8",
              "Bronze": "#78716C"
            }
          },
          "bounds": { "x": 462, "y": 460, "width": 470, "height": 245 }
        },
        {
          "type": "card",
          "title": "Revenue MTD",
          "measure": "Revenue MTD",
          "format": "#,##0",
          "bounds": { "x": 948, "y": 460, "width": 150, "height": 115 }
        },
        {
          "type": "card",
          "title": "Revenue YTD",
          "measure": "Revenue YTD",
          "format": "#,##0",
          "bounds": { "x": 1108, "y": 460, "width": 150, "height": 115 }
        },
        {
          "type": "kpi",
          "title": "MoM Growth",
          "measure": "Revenue MoM Growth %",
          "trendAxis": "Calendar[YearMonth]",
          "bounds": { "x": 948, "y": 590, "width": 310, "height": 115 }
        }
      ]
    },

    {
      "name": "02_Products",
      "displayName": "Sản phẩm & ML Predictions",
      "description": "Product performance, viral rate, similarity distribution.",
      "contentArea": {
        "x": 80, "y": 0, "width": 1200, "height": 720
      },

      "header": {
        "bounds": { "x": 80, "y": 0, "width": 1200, "height": 60 },
        "elements": [
          {
            "type": "textbox",
            "text": "🏷️ Phân tích Sản phẩm & ML Viral Prediction",
            "bounds": { "x": 96, "y": 12, "width": 500, "height": 36 }
          },
          {
            "type": "slicer",
            "field": "product_summary[category]",
            "slicerType": "Dropdown",
            "bounds": { "x": 940, "y": 10, "width": 160, "height": 40 }
          }
        ]
      },

      "visuals": [
        {
          "type": "treemap",
          "title": "Revenue theo sản phẩm",
          "group": "product_summary[category]",
          "details": "product_summary[product_name]",
          "values": ["Product Revenue"],
          "bounds": { "x": 96, "y": 70, "width": 580, "height": 310 },
          "notes": "Tooltip: total_orders, avg_price, viral_rate"
        },
        {
          "type": "clusteredBarChart",
          "title": "Top 10 sản phẩm — Đơn hàng",
          "axis": "product_summary[product_name]",
          "values": ["product_summary[total_orders]"],
          "topNFilter": { "n": 10, "direction": "DESC" },
          "bounds": { "x": 692, "y": 70, "width": 560, "height": 310 },
          "notes": "Sort by total_orders DESC, conditional color by viral_rate"
        },
        {
          "type": "gauge",
          "title": "Avg Viral Rate",
          "measure": "Avg Viral Rate",
          "min": 0,
          "max": 1,
          "target": 0.15,
          "bounds": { "x": 96, "y": 395, "width": 280, "height": 230 },
          "notes": "Target = threshold P95 từ notebook 04. Green > 0.15, Red < 0.05."
        },
        {
          "type": "clusteredColumnChart",
          "title": "Similarity Score Distribution",
          "axis": "similarity_scores[similarity_bin]",
          "values": ["Similarity Bin Count"],
          "legend": "similarity_scores[category]",
          "bounds": { "x": 392, "y": 395, "width": 480, "height": 310 },
          "notes": "Stacked columns — mỗi bin (0.0–1.0) hiện % phân phối"
        },
        {
          "type": "scatterChart",
          "title": "Similarity vs Viral %",
          "axis_x": "similarity_scores[similarity_bin]",
          "axis_y": "Similarity Viral %",
          "legend": "similarity_scores[category]",
          "bounds": { "x": 888, "y": 395, "width": 370, "height": 310 },
          "notes": "Scatter: mỗi bin × category → tỷ lệ viral. Trend line optional."
        }
      ]
    },

    {
      "name": "03_Customers",
      "displayName": "Khách hàng & CLV",
      "description": "Customer lifetime value, segments, top customers by revenue with time filter.",
      "contentArea": {
