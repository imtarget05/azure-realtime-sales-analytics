{
  "name": "Sales_Lakehouse_Pipeline",
  "description": "Full Lakehouse pipeline: Event Hub → Bronze → Silver → Feature Eng → ML → Gold (chạy mỗi 5 phút)",

  "tasks": [
    {
      "task_key": "bronze_ingestion",
      "description": "Đọc events từ Azure Event Hub → ghi vào Delta Lake Bronze",
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/azure-realtime-sales-analytics/databricks/notebooks/01_bronze_ingestion",
        "base_parameters": {},
        "source": "WORKSPACE"
      },
      "job_cluster_key": "etl_cluster",
      "timeout_seconds": 0,
      "max_retries": 2,
      "retry_on_timeout": true,
      "libraries": [
        { "maven": { "coordinates": "com.microsoft.azure:azure-eventhubs-spark_2.12:2.3.22" } }
      ]
    },
    {
      "task_key": "silver_etl",
      "description": "Làm sạch Bronze → tính toán → ghi Silver Delta",
      "depends_on": [
        { "task_key": "bronze_ingestion" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/azure-realtime-sales-analytics/databricks/notebooks/02_silver_etl",
        "base_parameters": {
          "pipeline.etl_mode": "batch"
        },
        "source": "WORKSPACE"
      },
      "job_cluster_key": "etl_cluster",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "retry_on_timeout": true
    },
    {
      "task_key": "feature_engineering",
      "description": "NLP features, Similarity Score, Viral labels → Gold/ml_features",
      "depends_on": [
        { "task_key": "silver_etl" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/azure-realtime-sales-analytics/databricks/notebooks/03_feature_engineering",
        "base_parameters": {},
        "source": "WORKSPACE"
      },
      "job_cluster_key": "ml_cluster",
      "timeout_seconds": 3600,
      "max_retries": 1,
      "retry_on_timeout": false
    },
    {
      "task_key": "ml_prediction",
      "description": "Load MLflow model → batch predict is_viral → Gold/viral_predictions",
      "depends_on": [
        { "task_key": "feature_engineering" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/azure-realtime-sales-analytics/databricks/notebooks/04_ml_prediction",
        "base_parameters": {
          "pipeline.ml_mode": "inference"
        },
        "source": "WORKSPACE"
      },
      "job_cluster_key": "ml_cluster",
      "timeout_seconds": 1800,
      "max_retries": 1,
      "retry_on_timeout": false
    },
    {
      "task_key": "gold_aggregation",
      "description": "Tạo bảng Gold tổng hợp + SQL Views cho Power BI",
      "depends_on": [
        { "task_key": "ml_prediction" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/azure-realtime-sales-analytics/databricks/notebooks/05_gold_aggregation",
        "base_parameters": {},
        "source": "WORKSPACE"
      },
      "job_cluster_key": "etl_cluster",
      "timeout_seconds": 1800,
      "max_retries": 2,
      "retry_on_timeout": true
    }
  ],

  "job_clusters": [
    {
      "job_cluster_key": "etl_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "autoscale": {
          "min_workers": 1,
          "max_workers": 4
        },
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.sql.shuffle.partitions": "auto",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true",
          "pipeline.storage_account": "salesdatalake",
          "pipeline.container": "lakehouse",
          "pipeline.eventhub_name": "sales-events",
          "pipeline.max_events_per_trigger": "10000"
        },
        "azure_attributes": {
          "availability": "ON_DEMAND_AZURE",
          "first_on_demand": 1,
          "spot_bid_max_price": -1
        },
        "runtime_engine": "PHOTON"
      }
    },
    {
      "job_cluster_key": "ml_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-ml-scala2.12",
        "node_type_id": "Standard_DS4_v2",
        "num_workers": 2,
        "autoscale": {
          "min_workers": 1,
          "max_workers": 4
        },
        "spark_conf": {
          "spark.sql.adaptive.enabled": "true",
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "pipeline.storage_account": "salesdatalake",
          "pipeline.container": "lakehouse",
          "pipeline.mlflow_model": "sales-viral-classifier",
          "pipeline.mlflow_stage": "Production"
        },
        "azure_attributes": {
          "availability": "ON_DEMAND_AZURE",
          "first_on_demand": 1,
          "spot_bid_max_price": -1
        }
      }
    }
  ],

  "schedule": {
    "quartz_cron_expression": "0 0/5 * * * ?",
    "timezone_id": "Asia/Ho_Chi_Minh",
    "pause_status": "UNPAUSED"
  },

  "continuous": {
    "_comment": "Nếu chạy streaming mode, bật continuous thay vì schedule",
    "_enabled": false,
    "pause_status": "UNPAUSED"
  },

  "email_notifications": {
    "on_failure": ["admin@yourdomain.com"],
    "on_success": [],
    "no_alert_for_skipped_runs": true
  },

  "webhook_notifications": {
    "on_failure": [
      {
        "id": "slack-webhook-id",
        "_comment": "Tạo Databricks notification destination → Slack/Teams"
      }
    ]
  },

  "max_concurrent_runs": 1,
  "queue": {
    "enabled": true
  },

  "tags": {
    "project": "sales-analytics",
    "layer": "bronze-silver",
    "team": "data-engineering"
  },

  "format": "MULTI_TASK"
}
