# ─────────────────────────────────────────────────────────────
# Mẫu biến môi trường cho hệ thống trực quan dữ liệu bán hàng
# Hướng dẫn:
#   cp .env.example .env
#   → điền thông tin Azure / API thực tế vào file .env
# ─────────────────────────────────────────────────────────────

# ── Azure Event Hubs ─────────────────────────────────────────
# Lấy từ Azure Portal → Event Hubs Namespace → Shared access policies
EVENT_HUB_CONNECTION_STRING=<Your-Event-Hub-Connection-String>
EVENT_HUB_NAME=sales-events

# ── Azure SQL Database ───────────────────────────────────────
# Lấy từ Azure Portal → SQL Database → Connection strings
SQL_SERVER=<your-server>.database.windows.net
SQL_DATABASE=SalesAnalyticsDB
SQL_USERNAME=<your-username>
SQL_PASSWORD=<your-password>
SQL_DRIVER={ODBC Driver 18 for SQL Server}

# ── Azure Machine Learning ───────────────────────────────────
# Lấy từ Azure Portal → Machine Learning → Endpoints
AML_WORKSPACE_NAME=<your-aml-workspace>
AML_SUBSCRIPTION_ID=<your-subscription-id>
AML_RESOURCE_GROUP=<your-resource-group>
AML_ENDPOINT_URL=<your-ml-endpoint-url>
AML_API_KEY=<your-ml-api-key>

# ── Azure Blob Storage ───────────────────────────────────────
# Lấy từ Azure Portal → Storage Account → Access keys
BLOB_CONNECTION_STRING=<Your-Blob-Storage-Connection-String>

# ── Azure Data Factory ───────────────────────────────────────
DATA_FACTORY_NAME=adf-sales-analytics

# ── Azure General ────────────────────────────────────────────
# Lấy từ Azure Portal → Subscriptions
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=rg-sales-analytics
AZURE_LOCATION=eastus

# ── External APIs: Weather / Holiday ────────────────────────
# OpenWeather: https://openweathermap.org/
OPENWEATHER_API_KEY=<your-openweather-api-key>

# Calendarific: https://calendarific.com/
CALENDARIFIC_API_KEY=<your-calendarific-api-key>

# ── Data Generator ───────────────────────────────────────────
# SALES_GENERATION_INTERVAL: thời gian chờ giữa các vòng sinh event (giây)
# BATCH_SIZE: số event gom lại trước khi gửi Event Hubs
SALES_GENERATION_INTERVAL=1.0
BATCH_SIZE=10

# Tốc độ mục tiêu theo phút, dùng cho live mode
RATE_PER_MINUTE=1200

# Burst mode
BURST_ENABLED=true
BURST_MULTIPLIER=3
BURST_DURATION_SECONDS=15

# Price shock mode (drift demo): tăng giá mạnh để mô phỏng market shift
PRICE_SHOCK_ENABLED=false
PRICE_SHOCK_MULTIPLIER=1.0
# Để trống = áp dụng cho mọi sản phẩm; hoặc ví dụ: COKE,PEPSI
PRICE_SHOCK_PRODUCTS=

# Replay mode
REPLAY_MODE=false
REPLAY_FILE=sample_events.jsonl

# Logging
LOG_LEVEL=INFO

# Retry / timeout cho Event Hubs
EVENT_HUB_MAX_RETRIES=5
EVENT_HUB_RETRY_BACKOFF_FACTOR=0.8
EVENT_HUB_RETRY_BACKOFF_MAX=30
EVENT_HUB_SEND_TIMEOUT=30
# Event Hub transport: AmqpOverWebsocket (recommended for restricted networks) or Amqp
EVENT_HUB_TRANSPORT=AmqpOverWebsocket

# Drift monitor -> GitHub Actions dispatch (optional)
DRIFT_TRIGGER_GITHUB_ACTIONS=false
GITHUB_REPO=<owner/repo>
GITHUB_WORKFLOW_FILE=ci-cd-mlops.yml
GITHUB_REF=main
GITHUB_TOKEN=<github-token-with-repo-scope>

# Cache TTL (giây)
WEATHER_CACHE_TTL=600
HOLIDAY_CACHE_TTL=86400

# Default country cho holiday lookup
DEFAULT_COUNTRY_CODE=VN

# ── Databricks (cho deploy_job.py) ──────────────────────────
# Lấy từ Azure Databricks → User Settings → Developer → Access tokens
DATABRICKS_HOST=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi-xxxxx