# ─────────────────────────────────────────────────────────────
# Mẫu biến môi trường cho hệ thống trực quan dữ liệu bán hàng
# Hướng dẫn: cp .env.example .env  →  điền thông tin Azure thực tế
# ─────────────────────────────────────────────────────────────

# ── Azure Event Hubs ─────────────────────────────────────────
# Lấy từ Azure Portal → Event Hubs Namespace → Shared access policies
EVENT_HUB_CONNECTION_STRING=<Your-Event-Hub-Connection-String>
EVENT_HUB_NAME=sales-events

# ── Azure SQL Database ────────────────────────────────────────
# Lấy từ Azure Portal → SQL Database → Connection strings
SQL_SERVER=<your-server>.database.windows.net
SQL_DATABASE=SalesAnalyticsDB
SQL_USERNAME=<your-username>
SQL_PASSWORD=<your-password>
SQL_DRIVER={ODBC Driver 18 for SQL Server}

# ── Azure Machine Learning ────────────────────────────────────
# Lấy từ Azure Portal → Machine Learning → Endpoints
AML_WORKSPACE_NAME=<your-aml-workspace>
AML_SUBSCRIPTION_ID=<your-subscription-id>
AML_RESOURCE_GROUP=<your-resource-group>
AML_ENDPOINT_URL=<your-ml-endpoint-url>
AML_API_KEY=<your-ml-api-key>

# ── Azure Blob Storage ────────────────────────────────────────
# Lấy từ Azure Portal → Storage Account → Access keys
BLOB_CONNECTION_STRING=<Your-Blob-Storage-Connection-String>

# ── Azure Data Factory ────────────────────────────────────────
DATA_FACTORY_NAME=adf-sales-analytics

# ── Azure General ─────────────────────────────────────────────
# Lấy từ Azure Portal → Subscriptions
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=rg-sales-analytics
AZURE_LOCATION=eastus

# ── Data Generator ────────────────────────────────────────────
# SALES_GENERATION_INTERVAL: thời gian chờ giữa các batch (giây)
SALES_GENERATION_INTERVAL=1.0
BATCH_SIZE=10
